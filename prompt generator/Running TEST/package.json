{
  "name": "running-test",
  "private": true,
  "version": "1.0.0",
  "type": "commonjs",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "build": "node vercel-build.js",
    "build:exe": "electron-builder --win --x64",
    "dist": "electron-builder --win --x64"
  },
  "build": {
    "appId": "com.runningtest.app",
    "productName": "Running TEST",
    "asar": true,
    "files": [
      "main.js",
      "server.js",
      "app.js",
      "styles.css",
      "Running sam.html",
      "package.json"
    ],
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": [
        "nsis"
      ]
    }
  },
  "devDependencies": {
    "electron": "^43.1.1",
    "electron-builder": "^26.15.3"
  }
}
